---
import "../styles/global.css";
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";
import ClickSound from "../components/clickSound.astro";
import { ViewTransitions } from "astro:transitions";

const title = Astro.props.title ?? "Portfolio";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />
  </head>

  <body>
      <Header />

    <h1 class="text-center mt-2">{title}</h1>

    <main>
      <slot />
    </main>

    <Footer />

    <!-- Persist musikk (så den fortsetter) -->
    <audio id="site-bgm" loop preload="none" data-astro-transition-persist>
      <source
        src="/sounds/629150__holizna__lofi-guitar-loop-em-119-bpm3.wav"
        type="audio/wav"
      />
    </audio>

    <script>
      declare global {
        interface Window {
          __bgm: {
            audio: HTMLAudioElement;
            play: () => Promise<void>;
            pause: () => void;
            isPlaying: () => boolean;
          };
        }
      }

      const audio = document.getElementById("site-bgm") as HTMLAudioElement;

      if (audio) {
        window.__bgm = {
          audio,
          play: async () => audio.play(),
          pause: () => audio.pause(),
          isPlaying: () => !audio.paused,
        };

        const saved = localStorage.getItem("musicEnabled") === "true";
        if (saved) {
          window.addEventListener(
            "pointerdown",
            async () => {
              try { await audio.play(); } catch {}
            },
            { once: true }
          );
        }
      }
    </script>

    <ClickSound />

    <script type="module">
      import "../scripts/menu.js";
    </script>

  </body>
</html>