<script>
  const clickSound = new Audio("/sounds/494493__sheyvan__button-clicking-7-single.wav");
  clickSound.volume = 0.25;

  document.addEventListener("click", (e) => {
    // Finn nærmeste knapp eller lenke som ble klikket
