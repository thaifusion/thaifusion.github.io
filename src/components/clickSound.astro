    if (!el) return;

    // Ikke spill lyd for eksterne linker (valgfritt)
    // const isExternal = el.tagName === "A" && el.href && !el.href.startsWith(location.origin);
    // if (isExternal) return;

    clickSound.currentTime = 0;
    clickSound.play().catch(() => {});
  });
</script>